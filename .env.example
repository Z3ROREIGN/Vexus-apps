# Configuração de Variáveis de Ambiente - Vexus Apps
# Copie este arquivo para .env e preencha com suas credenciais

# API Bitso - Obtenha em https://bitso.com/settings/api
BITSO_API_KEY=sua_chave_api_bitso_aqui
BITSO_API_SECRET=seu_secret_api_bitso_aqui

# Discord Webhook - Crie em: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_WEBHOOK_ID/SEU_WEBHOOK_TOKEN

# Instruções:
# 1. Renomeie este arquivo para .env
# 2. Preencha as variáveis acima com suas credenciais reais
# 3. Configure no Cloudflare usando: wrangler secret put NOME_DA_VARIAVEL
# 4. Nunca commite o arquivo .env no Git!
